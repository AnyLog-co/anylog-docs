---
layout: null
---
[
  {% for doc in site.docs %}
  {
    "url":     "{{ doc.url | relative_url }}",
    "title":   {{ doc.title   | jsonify }},
    "content": {{ doc.content | strip_html | strip_newlines | truncatewords: 100 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]